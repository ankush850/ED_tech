# Environment Variables — copy to .env.local and fill in your values

# PostgreSQL Database (required for Prisma)
# Options: Supabase (Settings > Database > Connection String > URI mode)
#          Neon.tech (free serverless Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/learnhub"

# Supabase (for video file storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase Storage bucket name (create a bucket called "videos" in Supabase Storage)
NEXT_PUBLIC_SUPABASE_BUCKET="videos"



# LiveKit Configuration
LIVEKIT_API_KEY="API key"
LIVEKIT_API_SECRET="placeholder_for_secret"
NEXT_PUBLIC_LIVEKIT_URL="wss://live-class-d74slaxs.livekit.cloud"
